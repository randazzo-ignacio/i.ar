# ── Prometheus Configuration ───────────────────────────────
# Scrape targets across the WireGuard mesh (10.66.0.x).
# Prometheus runs on daftpunk (10.66.0.3) and pulls from all hosts.

global:
  scrape_interval: 15s
  evaluation_interval: 15s

# ── Alert Rules ─────────────────────────────────────────────
rule_files:
  - "alert_rules.yml"

# ── Scrape Targets ───────────────────────────────────────────
scrape_configs:
  # Self-monitoring
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  # ── Node Exporters (all hosts) ────────────────────────────
  - job_name: "node_exporters"
    static_configs:
      - targets:
          # Cloud servers
          - "10.66.0.1:9100"   # rammstein
          - "10.66.0.2:9100"   # greenday
          - "10.66.0.3:9100"   # daftpunk
          # Local machines
          - "10.66.0.4:9100"   # yoga
          - "10.66.0.5:9100"   # sophon
        labels:
          group: "hosts"

  # ── cAdvisor (container metrics, hosts running Podman) ────
  - job_name: "cadvisor"
    static_configs:
      - targets:
          - "10.66.0.2:8081"   # greenday
          - "10.66.0.3:8081"   # daftpunk
          - "10.66.0.5:8081"   # sophon
        labels:
          group: "containers"

  # ── Ollama (if metrics endpoint available) ─────────────────
  - job_name: "ollama"
    static_configs:
      - targets:
          - "10.66.0.3:11434"  # daftpunk
          - "10.66.0.5:11434"  # sophon
        labels:
          group: "ai"
    metrics_path: /metrics