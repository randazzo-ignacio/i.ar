# {{ ansible_managed }}
# Frigate NVR — config.yaml
# Generated by Ansible role: frigate
# Do not edit manually; changes will be overwritten.

mqtt:
  enabled: {{ frigate_mqtt_enabled | bool }}

tls:
  enabled: {{ frigate_tls_enabled | bool }}

ffmpeg:
  hwaccel_args: preset-nvidia

record:
  enabled: true
  continuous:
    days: {{ frigate_record_continuous_days }}
  motion:
    days: {{ frigate_record_motion_days }}
  alerts:
    retain:
      days: {{ frigate_record_alerts_days }}
      mode: {{ frigate_record_alerts_mode }}
  detections:
    retain:
      days: {{ frigate_record_detections_days }}
      mode: {{ frigate_record_detections_mode }}

{% if frigate_cameras | length > 0 %}
cameras:
{% for cam_name, cam in frigate_cameras.items() %}
  {{ cam_name }}:
    enabled: true
    friendly_name: {{ cam.friendly_name | default(cam_name) }}
    ffmpeg:
      inputs:
        - path: rtsp://127.0.0.1:{{ frigate_rtsp_port }}/{{ cam_name }}
          input_args: preset-rtsp-restream
          roles:
{% for role in cam.roles | default(['detect', 'record']) %}
            - {{ role }}
{% endfor %}
    detect:
      width: {{ cam.width | default(frigate_detect_width) }}
      height: {{ cam.height | default(frigate_detect_height) }}
    live:
      streams:
        Stream 1: {{ cam_name }}
{% endfor %}
{% endif %}

go2rtc:
  streams:
{% for cam_name, cam in frigate_cameras.items() %}
    {{ cam_name }}:
      - rtsp://{{ frigate_camera_rtsp_user }}:{{ frigate_camera_rtsp_password }}@{{ cam.rtsp_host }}{{ cam.rtsp_path }}
{% endfor %}

version: 0.17-0